  "panels": [
    {
      "title": "Gate Executions (pass/fail)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(v939_gate_executions_total{status=\"pass\"})", "legendFormat": "PASS"},
        {"expr": "sum(v939_gate_executions_total{status=\"fail\"})", "legendFormat": "FAIL"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "title": "LLM Calls by Provider",
      "type": "piechart",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [
        {"expr": "sum by (provider) (v939_llm_calls_total)", "legendFormat": "{{provider}}"}
      ]
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "v939_cache_total{type=\"hit\"} / (v939_cache_total{type=\"hit\"} + v939_cache_total{type=\"miss\"}) * 100",
          "legendFormat": "hit rate %"
        }
      ],
      "fieldConfig": {"defaults": {"max": 100, "min": 0, "unit": "percent"}}
    },
    {
      "title": "Daemon Uptime",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "targets": [
        {"expr": "v939_daemon_uptime_seconds", "legendFormat": "uptime"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Gate Duration (avg seconds)",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {"expr": "v939_gate_duration_seconds{quantile=\"avg\"}", "legendFormat": "{{gate}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "LLM Duration by Provider (avg seconds)",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [
        {"expr": "v939_llm_duration_seconds{quantile=\"avg\"}", "legendFormat": "{{provider}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Tokens Saved by Cache",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 14},
      "targets": [
        {"expr": "v939_cache_total{type=\"hit\"}", "legendFormat": "cache hits"}
      ]
    },
    {
      "title": "Resources Loaded",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 22},
      "targets": [
        {"expr": "v939_daemon_resources_loaded", "legendFormat": "{{resource}}"}
      ]
    },
    {
      "title": "Cluster Workers",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 22},
      "targets": [
        {"expr": "v939_cluster_workers_active", "legendFormat": "active workers"}
      ]
    }
